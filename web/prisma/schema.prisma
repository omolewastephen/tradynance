// Tradynance — core ERD
// Prisma 6 conventional syntax — do NOT migrate to v7's prisma.config.ts + driver adapters.
// See CLAUDE.md and docs/ERD.md.
//
// Auth-provider tables (Account, Session, Verification, TwoFactor) were generated by
// @better-auth/cli against this schema in Phase 1 — don't hand-edit them; regenerate and
// reconcile the diff if better-auth's config changes.
//
// Money-correctness invariant (CLAUDE.md hard convention #3): Wallet.balance /
// Wallet.lockedBalance are CACHED, DERIVED values. The only source of truth for money
// movement is LedgerEntry, which is append-only — never update or delete a LedgerEntry.
// Every balance mutation happens by writing a new LedgerEntry and updating the wallet's
// cached balance in the same DB transaction. See packages/core/src/ledger.ts — both the
// Next.js app and the standalone services/chain-watcher process credit deposits through
// that one function so the invariant can't drift between the two processes.

generator client {
  provider = "prisma-client-js"
  output   = "../../packages/core/generated/prisma"
  // "native" = whatever the build machine is (local dev, Docker, Railway). Netlify builds on
  // Ubuntu but runs Functions on AWS Lambda (RHEL/OpenSSL 3), so the native engine won't load
  // there — add the Lambda target explicitly or every query fails at runtime (db:down).
  binaryTargets = ["native", "rhel-openssl-3.0.x", "rhel-openssl-1.0.x"]
}

datasource db {
  provider = "postgresql"
  // App/runtime connection. On serverless (Netlify) + Supabase this is the POOLED URL
  // (Supavisor, port 6543, transaction mode) so many short-lived function invocations don't
  // exhaust Postgres connections.
  url      = env("DATABASE_URL")
  // Migrations / introspection connection. On Supabase this is the DIRECT URL (port 5432) —
  // the pooler can't run schema DDL. Off Supabase (local, Docker, a plain Postgres) set it to
  // the SAME value as DATABASE_URL. Prisma requires the env var to exist, so it's set in every
  // env template.
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────────
// Identity & access
// ─────────────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  FINANCE
  SUPPORT
  COMPLIANCE
  MODERATOR
  DEVELOPER
  AUDITOR
  USER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  FROZEN
  BANNED
}

enum KycDocumentType {
  PASSPORT
  NATIONAL_ID
  DRIVERS_LICENSE
  RESIDENCE_PERMIT
}

/// What a compliance reviewer actually assesses. `User.kycStatus` stays the fast flag the rest of
/// the app checks (e.g. the withdrawal gate); this holds the evidence behind it. Submissions are
/// kept as history — a rejected attempt is never overwritten by a resubmission, so there's an
/// audit trail of what was reviewed and why.
model KycSubmission {
  id             String          @id @default(cuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id])
  legalName      String
  dateOfBirth    DateTime
  addressLine    String
  city           String
  postalCode     String
  country        String
  documentType   KycDocumentType
  documentNumber String

  /// Object paths inside the PRIVATE `kyc-documents` bucket — never public URLs. Identity
  /// documents are among the most sensitive data here; admins view them via short-lived signed
  /// URLs so the objects are never world-readable.
  frontPath  String
  backPath   String?
  selfiePath String?

  status          KycStatus @default(PENDING)
  rejectionReason String?
  reviewedById    String?
  reviewedAt      DateTime?
  createdAt       DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

enum KycStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

model User {
  id            String  @id @default(cuid())
  email         String  @unique
  username      String  @unique
  emailVerified Boolean @default(false)
  name          String?
  image         String?

  role      Role       @default(USER)
  status    UserStatus @default(ACTIVE)
  kycStatus KycStatus  @default(UNVERIFIED)

  country String?
  phone   String?

  antiPhishingCode String? // shown in transactional emails so users can spot spoofs

  // When true, withdrawals may only go to addresses in this user's WithdrawalWhitelist.
  withdrawalWhitelistOnly Boolean @default(false)

  referralCode String  @unique
  referredById String?
  referredBy   User?   @relation("Referrals", fields: [referredById], references: [id])
  referrals    User[]  @relation("Referrals")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  wallets             Wallet[]
  ledgerEntries       LedgerEntry[]
  deposits            Deposit[]
  withdrawals         Withdrawal[]
  withdrawalWhitelist WithdrawalWhitelist[]
  kycSubmissions      KycSubmission[]
  orders              Order[]
  conversions         Conversion[]
  auditLogs           AuditLog[]
  loginHistory        LoginHistory[]
  watchlist           Watchlist[]

  displayUsername  String?
  twoFactorEnabled Boolean?          @default(false)
  referralCodeUsed String?
  sessions         Session[]
  accounts         Account[]
  twofactors       TwoFactor[]
  futuresPositions FuturesPosition[]
  notifications    Notification[]

  commissionsEarned    ReferralCommission[]  @relation("CommissionsEarned")
  commissionsGenerated ReferralCommission[]  @relation("CommissionsGenerated")
  stakePositions       StakePosition[]
  launchpadCommitments LaunchpadCommitment[]
  nftsOwned            Nft[]                 @relation("NftOwner")
  nftListingsSelling   NftListing[]          @relation("NftSeller")
  nftPurchases         NftListing[]          @relation("NftBuyer")
  posts                Post[]

  @@index([status])
  @@index([kycStatus])
  @@index([createdAt]) // admin user list orders newest-first
  @@map("user")
}

// ─────────────────────────────────────────────────────────────────────────
// Assets & wallets
// ─────────────────────────────────────────────────────────────────────────

model Asset {
  id        String   @id @default(cuid())
  symbol    String   @unique // BTC, ETH, USDT...
  name      String
  decimals  Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  networks       AssetNetwork[]
  wallets        Wallet[]
  ledgerEntries  LedgerEntry[]
  deposits       Deposit[]
  withdrawals    Withdrawal[]
  baseMarkets    Market[]       @relation("MarketBase")
  quoteMarkets   Market[]       @relation("MarketQuote")
  conversionFrom Conversion[]   @relation("ConvertFrom")
  conversionTo   Conversion[]   @relation("ConvertTo")

  referralCommissions ReferralCommission[]
  stakingProducts     StakingProduct[]
  stakePositions      StakePosition[]
  launchpadTokens     LaunchpadProject[]   @relation("LaunchpadToken")
  launchpadSales      LaunchpadProject[]   @relation("LaunchpadSale")
}

model AssetNetwork {
  id              String  @id @default(cuid())
  assetId         String
  asset           Asset   @relation(fields: [assetId], references: [id])
  network         String // e.g. "BTC", "ERC20", "TRC20", "BEP20", "SOL"
  minDeposit      Decimal @db.Decimal(36, 18)
  withdrawalFee   Decimal @db.Decimal(36, 18)
  requiresMemo    Boolean @default(false)
  contractAddress String?
  // Platform receiving address for this coin/network, set by an admin in /admin/assets. When
  // present, the user deposit page shows THIS address (shared custodial model) instead of the
  // per-user HD-derived one. Set via admin, crediting is manual/reconciled.
  depositAddress  String?
  depositMemo     String?
  isActive        Boolean @default(true)

  @@unique([assetId, network])
}

model Wallet {
  id      String  @id @default(cuid())
  userId  String
  user    User    @relation(fields: [userId], references: [id])
  assetId String
  asset   Asset   @relation(fields: [assetId], references: [id])
  network String?

  // Cached/derived — see money-correctness invariant at top of file.
  balance       Decimal @default(0) @db.Decimal(36, 18)
  lockedBalance Decimal @default(0) @db.Decimal(36, 18) // held by open orders/withdrawals

  depositAddress  String?
  depositMemo     String?
  // Monotonic index into the HD wallet tree for this (network) — never reused across wallets,
  // so a given wallet always derives the same address. Assigned from GlobalCounter at
  // provisioning time. Null for wallets on networks we don't derive live addresses for yet.
  derivationIndex Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ledgerEntries LedgerEntry[]

  @@unique([userId, assetId, network])
  @@index([depositAddress])
}

// Source of monotonically-increasing HD derivation indexes, one row per network. Incremented
// inside the same transaction that provisions a Wallet so two wallets can never collide on an
// index (and therefore never share a deposit address).
model DerivationCounter {
  network   String   @id
  nextIndex Int      @default(0)
  updatedAt DateTime @updatedAt
}

// Custody consolidation record: funds moved from a user's per-user deposit address into the
// platform treasury/hot wallet. This is NOT a balance change — the user was already credited when
// the deposit was detected — so a sweep writes NO LedgerEntry. This row is the ops/audit trail.
// See packages/core/src/chain/sweep.ts.
model Sweep {
  id          String   @id @default(cuid())
  network     String
  userId      String?
  fromAddress String
  toAddress   String // treasury
  amount      Decimal  @db.Decimal(36, 18)
  txHash      String   @unique
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

enum LedgerEntryType {
  DEPOSIT
  WITHDRAWAL
  TRADE_FILL
  FEE
  TRANSFER_IN
  TRANSFER_OUT
  CONVERSION
  ADJUSTMENT
  FUTURES_MARGIN // collateral moved into a futures position on open
  FUTURES_PNL // margin + realized PnL returned to the wallet on close
  FUNDING // periodic perp funding payment
  LIQUIDATION // residual equity returned when a position is force-closed
  REFERRAL_COMMISSION // rebate credited to a referrer from a referee's trading fee
  STAKE // principal moved out to / back from a stake position (signed)
  STAKING_REWARD // yield credited on redeeming a stake
  LAUNCHPAD // sale-asset paid on commit / token received on claim (signed)
  NFT // marketplace payment: buyer debited / seller credited (signed)
}

enum LedgerEntryStatus {
  PENDING
  CONFIRMED
  REVERSED
}

// Append-only. No update/delete from application code — corrections are new entries
// (e.g. an ADJUSTMENT or a reversing entry referencing the original by id in `note`).

model LedgerEntry {
  id       String @id @default(cuid())
  walletId String
  wallet   Wallet @relation(fields: [walletId], references: [id])
  userId   String
  user     User   @relation(fields: [userId], references: [id])
  assetId  String
  asset    Asset  @relation(fields: [assetId], references: [id])

  type         LedgerEntryType
  status       LedgerEntryStatus @default(PENDING)
  amount       Decimal           @db.Decimal(36, 18) // signed: +credit / -debit
  balanceAfter Decimal           @db.Decimal(36, 18) // snapshot for reconciliation

  referenceType String? // "Deposit" | "Withdrawal" | "Order" | "Trade" | ...
  referenceId   String?
  note          String?

  createdAt DateTime @default(now())

  @@index([walletId, createdAt])
  @@index([userId])
  @@index([referenceType, referenceId])
}

// ─────────────────────────────────────────────────────────────────────────
// Deposits & withdrawals
// ─────────────────────────────────────────────────────────────────────────

enum DepositStatus {
  PENDING
  CONFIRMED
  CREDITED
  REJECTED
}

model Deposit {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  assetId       String
  asset         Asset         @relation(fields: [assetId], references: [id])
  network       String
  amount        Decimal       @db.Decimal(36, 18)
  txHash        String?
  // Output index within the tx (BTC vout / EVM log index). Together with (network, txHash)
  // this uniquely identifies one credit-able transfer so the watcher can't double-count.
  txOutputIndex Int           @default(0)
  fromAddress   String?
  toAddress     String
  confirmations Int           @default(0)
  status        DepositStatus @default(PENDING)
  source        DepositSource @default(CHAIN)
  creditedAt    DateTime?
  createdAt     DateTime      @default(now())

  // Idempotency key for on-chain detection: one (network, txHash, output) can only ever
  // produce one Deposit row, so a re-scan or a watcher restart can't credit twice. Manual
  // admin credits set a synthetic txHash so they don't collide with real ones.
  @@unique([network, txHash, txOutputIndex])
  @@index([userId, status])
  @@index([txHash])
}

enum DepositSource {
  CHAIN // detected by chain-watcher
  MANUAL // admin-confirmed fallback (admin-initiated)
  CLAIM // user-submitted "I've paid" claim, awaiting admin review/approval
}

enum WithdrawalStatus {
  AWAITING_CONFIRMATION // created, waiting on email OTP + 2FA/password; funds NOT yet locked
  PENDING // confirmed, funds locked, awaiting admin approval
  APPROVED // admin approved, being sent on-chain
  PROCESSING
  COMPLETED // settled: ledger debit written, funds left the account
  REJECTED
  CANCELLED
}

model Withdrawal {
  id                 String           @id @default(cuid())
  userId             String
  user               User             @relation(fields: [userId], references: [id])
  assetId            String
  asset              Asset            @relation(fields: [assetId], references: [id])
  network            String
  amount             Decimal          @db.Decimal(36, 18)
  fee                Decimal          @db.Decimal(36, 18)
  destinationAddress String
  destinationMemo    String?
  txHash             String?
  status             WithdrawalStatus @default(AWAITING_CONFIRMATION)

  // Confirmation gate — an email OTP (hashed, single-use, short-lived). The second factor
  // (TOTP if 2FA enabled, else password) is verified live at confirm time, not stored.
  confirmationCodeHash  String?
  confirmationExpiresAt DateTime?
  confirmedAt           DateTime?

  approvedById   String?
  approvedAt     DateTime?
  rejectedReason String?
  createdAt      DateTime  @default(now())

  @@index([userId, status])
}

// Per-user address book of trusted withdrawal destinations. Network-scoped because an
// address is valid for a chain, not a single token (one ERC-20 address receives any ERC-20).
// If a user has `withdrawalWhitelistOnly` set, withdrawals may only target these.
model WithdrawalWhitelist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  network   String
  address   String
  memo      String?
  label     String
  createdAt DateTime @default(now())

  @@unique([userId, network, address])
  @@index([userId])
}

// Instant asset conversion (swap) record. Settlement is a pair of CONVERSION ledger entries
// (see packages/core/src/convert.ts); this row is the user-facing history with the effective
// rate. `rate` = toAmount / fromAmount (already net of spread).
model Conversion {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  fromAssetId String
  fromAsset   Asset    @relation("ConvertFrom", fields: [fromAssetId], references: [id])
  toAssetId   String
  toAsset     Asset    @relation("ConvertTo", fields: [toAssetId], references: [id])
  fromAmount  Decimal  @db.Decimal(36, 18)
  toAmount    Decimal  @db.Decimal(36, 18)
  rate        Decimal  @db.Decimal(36, 18)
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────
// Markets & spot trading
// ─────────────────────────────────────────────────────────────────────────

model Market {
  id           String @id @default(cuid())
  symbol       String @unique // "BTCUSDT"
  baseAssetId  String
  baseAsset    Asset  @relation("MarketBase", fields: [baseAssetId], references: [id])
  quoteAssetId String
  quoteAsset   Asset  @relation("MarketQuote", fields: [quoteAssetId], references: [id])

  // Symbol on the upstream market-data source (data-api.binance.vision). Usually == symbol.
  dataSourceSymbol String?

  isActive          Boolean @default(true)
  minOrderSize      Decimal @db.Decimal(36, 18)
  pricePrecision    Int
  quantityPrecision Int
  makerFeeBps       Int     @default(10)
  takerFeeBps       Int     @default(20)

  orders           Order[]
  trades           Trade[]
  ticker           Ticker?
  watchedBy        Watchlist[]
  futuresPositions FuturesPosition[]

  @@index([baseAssetId, quoteAssetId])
}

// Latest live price + 24h stats per market, upserted by services/market-data. One row per
// market; a cache of upstream data, not a source of truth for anything money-related.
model Ticker {
  id                 String   @id @default(cuid())
  marketId           String   @unique
  market             Market   @relation(fields: [marketId], references: [id])
  lastPrice          Decimal  @db.Decimal(36, 18)
  priceChangePercent Decimal  @db.Decimal(18, 4)
  high24h            Decimal  @db.Decimal(36, 18)
  low24h             Decimal  @db.Decimal(36, 18)
  volume             Decimal  @db.Decimal(36, 8) // base-asset volume
  quoteVolume        Decimal  @db.Decimal(36, 8) // quote-asset (USDT) volume
  updatedAt          DateTime @updatedAt
}

model Watchlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  marketId  String
  market    Market   @relation(fields: [marketId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, marketId])
  @@index([userId])
}

enum OrderSide {
  BUY
  SELL
}

enum OrderType {
  MARKET
  LIMIT
}

enum TimeInForce {
  GTC
  IOC
  FOK
}

enum OrderStatus {
  OPEN
  PARTIALLY_FILLED
  FILLED
  CANCELLED
  REJECTED
}

model Order {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id])
  marketId String
  market   Market @relation(fields: [marketId], references: [id])

  side            OrderSide
  type            OrderType
  timeInForce     TimeInForce @default(GTC)
  price           Decimal?    @db.Decimal(36, 18) // null for market orders
  quantity        Decimal     @db.Decimal(36, 18) // base-asset quantity
  filledQuantity  Decimal     @default(0) @db.Decimal(36, 18)
  // Running quote total filled (Σ price×qty) and derived avg fill price, for display.
  cumulativeQuote Decimal     @default(0) @db.Decimal(36, 18)
  avgFillPrice    Decimal?    @db.Decimal(36, 18)
  status          OrderStatus @default(OPEN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buyTrades  Trade[] @relation("BuyOrder")
  sellTrades Trade[] @relation("SellOrder")

  // Order-book queries scan resting orders by market/side/status ordered by price.
  @@index([marketId, side, status, price])
  @@index([marketId, status])
  @@index([userId])
}

model Trade {
  id          String @id @default(cuid())
  marketId    String
  market      Market @relation(fields: [marketId], references: [id])
  buyOrderId  String
  buyOrder    Order  @relation("BuyOrder", fields: [buyOrderId], references: [id])
  sellOrderId String
  sellOrder   Order  @relation("SellOrder", fields: [sellOrderId], references: [id])

  price     Decimal   @db.Decimal(36, 18)
  quantity  Decimal   @db.Decimal(36, 18)
  buyerFee  Decimal   @db.Decimal(36, 18)
  sellerFee Decimal   @db.Decimal(36, 18)
  takerSide OrderSide // which side crossed the spread — colors the trades feed

  createdAt DateTime @default(now())

  @@index([marketId, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────
// Margin & futures (isolated-margin perpetuals)
// ─────────────────────────────────────────────────────────────────────────

enum PositionSide {
  LONG
  SHORT
}

enum PositionStatus {
  OPEN
  CLOSED
  LIQUIDATED
}

// One isolated-margin perpetual position. Collateral (`margin`, in the quote asset) is moved
// out of the user's SPOT wallet on open and settled back (± realized PnL, ∓ funding) on close.
// See packages/core/src/futures.ts. Cross margin + advanced order types are deferred.
model FuturesPosition {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id])
  marketId String
  market   Market @relation(fields: [marketId], references: [id])

  side       PositionSide
  leverage   Int
  size       Decimal      @db.Decimal(36, 18) // base-asset contracts = (margin × leverage) / entryPrice
  entryPrice Decimal      @db.Decimal(36, 18)
  margin     Decimal      @db.Decimal(36, 18) // isolated collateral in quote (USDT)

  liquidationPrice Decimal  @db.Decimal(36, 18) // display; engine uses equity-based check
  fundingAccrued   Decimal  @default(0) @db.Decimal(36, 18) // + = user has paid net funding
  realizedPnl      Decimal  @default(0) @db.Decimal(36, 18)
  closePrice       Decimal? @db.Decimal(36, 18)

  status   PositionStatus @default(OPEN)
  openedAt DateTime       @default(now())
  closedAt DateTime?

  @@index([userId, status])
  @@index([marketId, status])
}

// One rebate a referrer earns from a referee's trading fee. Derived from a single FEE
// LedgerEntry (`ledgerEntryId` unique = idempotency key), settled by
// packages/core/src/referrals.ts. The commission credit itself is a REFERRAL_COMMISSION
// LedgerEntry on the referrer's SPOT wallet.
model ReferralCommission {
  id         String @id @default(cuid())
  referrerId String
  referrer   User   @relation("CommissionsEarned", fields: [referrerId], references: [id])
  refereeId  String
  referee    User   @relation("CommissionsGenerated", fields: [refereeId], references: [id])

  ledgerEntryId    String  @unique // the FEE entry this is derived from
  assetId          String
  asset            Asset   @relation(fields: [assetId], references: [id])
  feeAmount        Decimal @db.Decimal(36, 18)
  rateBps          Int
  commissionAmount Decimal @db.Decimal(36, 18)

  createdAt DateTime @default(now())

  @@index([referrerId, createdAt])
  @@index([refereeId])
}

// ─────────────────────────────────────────────────────────────────────────
// Staking — lock an asset for yield. Principal moves out of the SPOT wallet on stake and back
// (+ reward) on redeem, via STAKE / STAKING_REWARD ledger entries. Rewards accrue continuously
// and are computed on demand from elapsed time (see packages/core/src/staking.ts) — no separate
// accrual job needed. Reward comes from platform yield (an unmodeled source, like trade fees).
// ─────────────────────────────────────────────────────────────────────────

model StakingProduct {
  id       String  @id @default(cuid())
  assetId  String
  asset    Asset   @relation(fields: [assetId], references: [id])
  name     String
  aprBps   Int // annual rate in bps (800 = 8%)
  lockDays Int // 0 = flexible (redeem anytime)
  minStake Decimal @db.Decimal(36, 18)
  isActive Boolean @default(true)

  createdAt DateTime        @default(now())
  positions StakePosition[]
}

enum StakeStatus {
  ACTIVE
  REDEEMED
}

model StakePosition {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id])
  productId String
  product   StakingProduct @relation(fields: [productId], references: [id])
  assetId   String
  asset     Asset          @relation(fields: [assetId], references: [id])

  principal  Decimal     @db.Decimal(36, 18)
  aprBps     Int // snapshot at stake time
  lockDays   Int // snapshot at stake time
  startAt    DateTime    @default(now())
  unlockAt   DateTime? // startAt + lockDays (null for flexible)
  status     StakeStatus @default(ACTIVE)
  rewardPaid Decimal     @default(0) @db.Decimal(36, 18)
  redeemedAt DateTime?

  @@index([userId, status])
}

// ─────────────────────────────────────────────────────────────────────────
// Launchpad — token sales. Committing debits the sale asset (USDT) from the SPOT wallet and
// allocates tokens; claiming (after the sale is distributed) credits the token asset. Both are
// LAUNCHPAD ledger entries. See packages/core/src/launchpad.ts.
// ─────────────────────────────────────────────────────────────────────────

enum LaunchpadStatus {
  UPCOMING
  LIVE
  ENDED
  DISTRIBUTED
}

model LaunchpadProject {
  id           String @id @default(cuid())
  name         String
  tokenSymbol  String
  tokenAssetId String
  tokenAsset   Asset  @relation("LaunchpadToken", fields: [tokenAssetId], references: [id])
  saleAssetId  String
  saleAsset    Asset  @relation("LaunchpadSale", fields: [saleAssetId], references: [id])

  tokenPrice      Decimal @db.Decimal(36, 18) // sale asset per token
  totalAllocation Decimal @db.Decimal(36, 18) // tokens for sale
  soldAllocation  Decimal @default(0) @db.Decimal(36, 18)
  minCommit       Decimal @db.Decimal(36, 18) // in sale asset
  maxCommit       Decimal @db.Decimal(36, 18) // in sale asset, per user

  startAt     DateTime
  endAt       DateTime
  status      LaunchpadStatus @default(UPCOMING)
  description String

  createdAt   DateTime              @default(now())
  commitments LaunchpadCommitment[]
}

model LaunchpadCommitment {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  projectId String
  project   LaunchpadProject @relation(fields: [projectId], references: [id])

  committedAmount Decimal   @db.Decimal(36, 18) // total in sale asset
  tokenAmount     Decimal   @db.Decimal(36, 18) // total allocated tokens
  claimed         Boolean   @default(false)
  claimedAt       DateTime?
  createdAt       DateTime  @default(now())

  @@unique([userId, projectId])
}

// ─────────────────────────────────────────────────────────────────────────
// NFT marketplace. NFTs are unique (ownership = Nft.ownerId, not a wallet balance); only the
// USDT payment flows through the ledger. Buying transfers ownership and debits the buyer /
// credits the seller (minus a marketplace fee) in one transaction. See packages/core/src/nft.ts.
// ─────────────────────────────────────────────────────────────────────────

model NftCollection {
  id          String   @id @default(cuid())
  name        String
  symbol      String   @unique
  description String
  createdAt   DateTime @default(now())
  nfts        Nft[]
}

model Nft {
  id           String        @id @default(cuid())
  collectionId String
  collection   NftCollection @relation(fields: [collectionId], references: [id])
  tokenId      Int
  name         String
  imageSeed    String // deterministic seed → generated SVG art (no external assets)
  ownerId      String
  owner        User          @relation("NftOwner", fields: [ownerId], references: [id])
  createdAt    DateTime      @default(now())
  listings     NftListing[]

  @@unique([collectionId, tokenId])
  @@index([ownerId])
}

enum ListingStatus {
  ACTIVE
  SOLD
  CANCELLED
}

model NftListing {
  id       String  @id @default(cuid())
  nftId    String
  nft      Nft     @relation(fields: [nftId], references: [id])
  sellerId String
  seller   User    @relation("NftSeller", fields: [sellerId], references: [id])
  buyerId  String?
  buyer    User?   @relation("NftBuyer", fields: [buyerId], references: [id])

  price  Decimal       @db.Decimal(36, 18) // in USDT
  status ListingStatus @default(ACTIVE)

  createdAt DateTime  @default(now())
  soldAt    DateTime?

  @@index([status, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────
// Notifications (in-app; written by core money events + the app/service layers)
// ─────────────────────────────────────────────────────────────────────────

enum NotificationType {
  DEPOSIT
  WITHDRAWAL
  TRADE
  LIQUIDATION
  REFERRAL
  STAKING
  LAUNCHPAD
  SECURITY
  SYSTEM
}

model Notification {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  type  NotificationType
  title String
  body  String
  read  Boolean          @default(false)

  referenceType String? // e.g. "Deposit", "Withdrawal", "Order", "FuturesPosition"
  referenceId   String?

  createdAt DateTime @default(now())

  @@index([userId, read, createdAt])
  @@index([userId, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────
// Marketing site CMS — admin-managed public content (blog, contact inbox, editable copy).
// ─────────────────────────────────────────────────────────────────────────

enum PostStatus {
  DRAFT
  PUBLISHED
}

model Post {
  id        String     @id @default(cuid())
  title     String
  slug      String     @unique
  excerpt   String
  content   String // markdown body
  coverSeed String // deterministic generated cover art (see nft-art)
  category  String?
  status    PostStatus @default(DRAFT)
  authorId  String?
  author    User?      @relation(fields: [authorId], references: [id])

  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, publishedAt])
}

enum MessageStatus {
  NEW
  READ
  ARCHIVED
}

model ContactMessage {
  id        String        @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  status    MessageStatus @default(NEW)
  createdAt DateTime      @default(now())

  @@index([status, createdAt])
}

// Editable marketing copy, keyed like "home.hero.title". Pages fall back to code defaults when a
// key isn't overridden, so the site works before anything is edited in admin. See lib/site-content.
model SiteContent {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────
// Audit
// ─────────────────────────────────────────────────────────────────────────

// Nothing here is ever deleted or updated by application code.

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id])
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt]) // the admin audit viewer orders by newest-first
}

// Append-only record of every sign-in, distinct from the (ephemeral, deletable) Session
// table — written via a better-auth session.create databaseHook so it survives sign-out
// and session expiry cleanup.

model LoginHistory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model TwoFactor {
  id                      String    @id
  secret                  String
  backupCodes             String
  userId                  String
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  verified                Boolean?  @default(true)
  failedVerificationCount Int?      @default(0)
  lockedUntil             DateTime?

  @@index([secret])
  @@index([userId])
  @@map("twoFactor")
}

// better-auth "database" rate-limit storage — shared across web replicas (vs. the default in-memory
// per-process limiter). Managed entirely by better-auth; do not write to it from app code.
model RateLimit {
  id          String  @id
  key         String?
  count       Int?
  lastRequest BigInt?

  @@map("rateLimit")
}
