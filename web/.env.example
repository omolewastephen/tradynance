# Postgres. DATABASE_URL is the app/runtime connection; DIRECT_URL is used only by
# `prisma migrate`/`generate`. Off Supabase (local, Docker, plain Postgres) set them to the SAME
# value. On Supabase, DATABASE_URL = the POOLED URL (Supavisor, port 6543, add
# ?pgbouncer=true&connection_limit=1) and DIRECT_URL = the DIRECT URL (port 5432). Both required.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tradynance?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/tradynance?schema=public"
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Custody hot-wallet — deposit addresses are derived from this single BIP-39 mnemonic.
# TESTNET/DEV ONLY here. In production this MUST come from a secrets manager, never a file.
# See packages/core/src/wallet/derivation.ts and the compliance note in CLAUDE.md.
HD_WALLET_MNEMONIC=""
# The custodial hot wallet that signs on-chain withdrawals is derived at this address index of the
# mnemonic (kept clear of user deposit indexes). It must hold testnet funds to broadcast — see
# packages/core/src/chain/evm-withdraw.ts and scripts/broadcast-check.ts.
HOT_WALLET_INDEX="0"

# Chain endpoints used by services/chain-watcher (and shared with the app where needed).
# Defaults are public testnet endpoints; swap for your own keys/nodes in production.
BTC_TESTNET_ESPLORA_URL="https://blockstream.info/testnet/api"
ETH_SEPOLIA_RPC_URL="https://ethereum-sepolia-rpc.publicnode.com"

# How many confirmations before a detected deposit is auto-credited.
DEPOSIT_MIN_CONFIRMATIONS_BTC="1"
DEPOSIT_MIN_CONFIRMATIONS_ETH="3"

# Live market-data source (public Binance data mirror, no key). Polled by services/market-data.
MARKET_DATA_API_URL="https://data-api.binance.vision"
MARKET_DATA_POLL_MS="10000"

# Transactional email — transports are tried in this order (see src/lib/email.ts):
#   1a. ZEPTOMAIL_TOKEN — Zoho's transactional HTTP API. Create a Mail Agent in ZeptoMail, verify
#       your domain, copy its "Send Mail Token". Set ZEPTOMAIL_ENDPOINT if you're not on the US
#       datacentre (https://api.zeptomail.eu/v1.1/email, .in, etc.).
#   1b. RESEND_API_KEY  — Resend's HTTP API (alternative to ZeptoMail).
#   2.  SMTP_HOST       — plain SMTP. Correct for a VPS/Docker/Railway, but **serverless hosts
#       (Netlify/Vercel = AWS Lambda) block outbound SMTP on 465/587**, so it silently fails there.
#       Use an HTTP transport above in production; SMTP is the fallback.
#   3.  Console         — nothing configured: codes log to the server console (testable in dev).
# EMAIL_FROM must be a sender your provider has verified (a domain you own).
ZEPTOMAIL_TOKEN=""
# ZEPTOMAIL_ENDPOINT="https://api.zeptomail.com/v1.1/email"
RESEND_API_KEY=""
SMTP_HOST=""
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="Tradynance <no-reply@tradynance.com>"

# WalletConnect (pay-from-your-wallet deposits) — OPTIONAL. Browser wallets (MetaMask) work
# without it; set a project id (cloud.walletconnect.com) to also enable WalletConnect mobile/QR.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=""

# Error monitoring (Sentry) — OPTIONAL. Leave blank to disable entirely: no network, no overhead,
# dev unaffected. Set in production to turn on server + browser error reporting. Wiring lives in
# src/instrumentation.ts, src/instrumentation-client.ts and src/lib/observability.ts.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
# SENTRY_TRACES_SAMPLE_RATE="0.1"

# Redis — shared rate limiting across web replicas. UNSET = the app limiter runs in-process
# (fine for a single web instance). SET it to run multiple web replicas safely (app-level limits
# go to Redis; better-auth's limits go to the RateLimit table). e.g. redis://default:PASS@host:6379
REDIS_URL=""
