# Tradynance production env (docker compose). Copy to `.env`, fill in, keep it secret.
#   cp .env.docker.example .env

# ── Postgres (the `postgres` service reads these; DATABASE_URL must match) ──
POSTGRES_USER=tradynance
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=tradynance
# Host is the compose service name `postgres`, not localhost.
DATABASE_URL=postgresql://tradynance:CHANGE_ME_strong_db_password@postgres:5432/tradynance?schema=public
# Prisma migrate/generate connection. No separate pooler here, so same value as DATABASE_URL.
DIRECT_URL=postgresql://tradynance:CHANGE_ME_strong_db_password@postgres:5432/tradynance?schema=public

# ── Auth ──
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=CHANGE_ME_random_32_bytes
# IMPORTANT: these MUST exactly match the public origin the app is served on (scheme + host + port).
# The auth client fetches this origin from the browser, and the CSP `connect-src 'self'` blocks a
# mismatch. e.g. https://app.tradynance.com  — NOT localhost in production.
BETTER_AUTH_URL=https://app.example.com
NEXT_PUBLIC_APP_URL=https://app.example.com

# ── Custody hot wallet (TESTNET/DEV values only in this repo — use a secrets manager in prod) ──
HD_WALLET_MNEMONIC=""
TREASURY_ACCOUNT_INDEX=1

# ── Chains (services/chain-watcher + withdrawal broadcast + sweeper) ──
BTC_TESTNET_ESPLORA_URL=https://blockstream.info/testnet/api
ETH_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
DEPOSIT_MIN_CONFIRMATIONS_BTC=1
DEPOSIT_MIN_CONFIRMATIONS_ETH=3

# ── Market data ──
MARKET_DATA_API_URL=https://data-api.binance.vision
MARKET_DATA_POLL_MS=10000

# ── Transactional email (Resend) — leave blank to log to console ──
RESEND_API_KEY=""
EMAIL_FROM="Tradynance <onboarding@resend.dev>"

# ── Error monitoring (Sentry) — leave blank to disable ──
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# ── WalletConnect (pay-from-wallet) — optional ──
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=""

# ── Redis (available for future multi-instance rate limiting / cache) ──
REDIS_URL=redis://redis:6379
